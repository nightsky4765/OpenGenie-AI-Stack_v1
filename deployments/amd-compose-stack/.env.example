# =====================================================================
# TigerAI ARM64 Global Tuning Profile (Master Sync v6.9.9)
# Synced from src/0105-AMD Verified Enterprise Configurations
# =====================================================================

# --- Auto-Tuning Configuration ---
TIGER_OPTIMIZATION_PROFILE=BALANCED
TIGER_CPU_THREADS=24
TIGER_N8N_WORKERS=5
TIGER_LOG_MAX_SIZE=50m
TIGER_GPU_TYPE=AMD
TIGER_VRAM=0
CLUSTER_MODE=standalone
PRIMARY_NODE_IP=127.0.0.1
INSTALL_HA=false

# --- 1) Global Localization & System ---
TZ=Asia/Taipei
TIMEZONE=Asia/Taipei
PG_LANG=zh-TW
PORTAINER_PORT=9000

# --- 2) Database Excellence (Postgres v17 + pgAdmin 8.14) ---
PG_USER=adm
PG_PASS=CHANGE_ME
PG_DB_NAME=tigerai
PG_DB=tigerai
PG_PORT=5432

PGADMIN_PORT=8000
PGADMIN_EMAIL=CHANGE_ME
PGADMIN_PASS=CHANGE_ME

# --- 3) AI Interface (Ollama + OpenWebUI HA) ---
OWUI_PORT=8080
OWUI_SECRET_KEY=CHANGE_ME
OWUI_SCHEMA=openwebui
PG_HOST=postgres
SHM_SIZE=4gb

# Ollama Performance
OLLAMA_PORT=11434
OLLAMA_FLASH_ATTENTION=1
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=-1
OLLAMA_MAX_QUEUE=512
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_ORIGINS=*

# OpenWebUI Performance
GUNICORN_WORKERS=4
AIOHTTP_TIMEOUT=900

# --- 4) Automation (n8n Enterprise v2.x) ---
N8N_SECRET=CHANGE_ME
N8N_BINARY_DATA_MODE=filesystem
N8N_DIR=/home/wrt/TigerAI/node/n8n
FILES_DIR=/home/wrt/TigerAI/node/n8n/files
N8N_PORT=5678
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=tigerai
DB_POSTGRESDB_USER=adm
DB_POSTGRESDB_PASSWORD=CHANGE_ME
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_SCHEMA=public
REDIS_HOST=redis
WORKER_CONCURRENCY=5
N8N_URL=http://host.docker.internal:5678

# --- 5) RAG & Memory ---
QDRANT_PORT=6333
MQTT_BROKER_PORT=443
HTTP_DOCLING_PORT=5001
SHM_SIZE_RAG=16gb
DOCLING_SHM=16gb
MQTT_IMAGE=eclipse-mosquitto:latest
BASE_DIR=.

# --- 6) Landing Portal (Phase 13) ---
LANDING_PORT=80
LANDING_PORT_SSL=443
GATEWAY_API_URL=http://system-api-bridge:8000

# --- 7) Monitoring & Observability ---
GRAFANA_PORT=3000
GRAFANA_PASS=CHANGE_ME

# --- 12) commercial gateway ---
SYSTEM_API_GATEWAY_PORT=5055

# --- 9) Lemonade AI Core (PPA install) ---
# Pin specific PPA version (apt version string). Leave empty for latest.
# Examples: 10.2.0~24.04, 10.1.0~24.04, 10.0.1~24.04
LEMONADE_PPA_VERSION=10.0.1~24.04
LEMONADE_API_KEY=CHANGE_ME
BASE_DIR=/home/wrt/TigerAI
MODELS_DIR=/home/wrt/TigerAI/models
LOG_DIR=/home/wrt/TigerAI/logs
LLM_MODEL=/home/wrt/TigerAI/models/llm.gguf
EMBED_MODEL=/home/wrt/TigerAI/models/embed.gguf
USER_NAME=wrt
GGML_VULKAN_DEVICE_EDU=0
GGML_VULKAN_DEVICE_RAG=0
GGML_VULKAN_DEVICE_EMBED=0

# --- 8) Image Versions ---
PG_IMAGE=postgres:17-alpine
PGADMIN_IMAGE=dpage/pgadmin4:latest
OLLAMA_IMAGE=ollama/ollama:latest
OWUI_IMAGE=ghcr.io/open-webui/open-webui:main
REDIS_IMAGE=redis/redis-stack-server:latest
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
QDRANT_IMAGE=qdrant/qdrant:latest
MOSQUITTO_IMAGE=eclipse-mosquitto:latest
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve-cpu:latest
WEBSSH_IMAGE=jrohy/webssh:latest
PORTAINER_IMAGE=portainer/portainer-ce:latest
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
LOKI_IMAGE=grafana/loki:latest
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:latest
DCGM_EXPORTER_IMAGE=nvidia/dcgm-exporter:latest
ROCM_EXPORTER_IMAGE=rocm/device-metrics-exporter:v1.4.2
