{
    "title": "AMD GPU Monitoring",
    "tags": [
        "gpu",
        "amd",
        "rocm"
    ],
    "timezone": "browser",
    "panels": [
        {
            "id": 1,
            "title": "GPU Utilization",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rocm_gpu_utilization_percent",
                    "legendFormat": "GPU {{gpu_id}}",
                    "refId": "A"
                }
            ],
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "max": 100,
                    "min": 0
                },
                "overrides": []
            }
        },
        {
            "id": 2,
            "title": "GPU Memory Usage",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "100 * (rocm_gpu_vram_used_mb / clamp_min(rocm_gpu_vram_total_mb, 1))",
                    "legendFormat": "GPU {{gpu_id}}",
                    "refId": "A"
                }
            ],
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "max": 100,
                    "min": 0
                },
                "overrides": []
            }
        },
        {
            "id": 3,
            "title": "GPU Temperature",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rocm_gpu_temperature_celsius",
                    "legendFormat": "GPU {{gpu_id}}",
                    "refId": "A"
                }
            ],
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "celsius"
                },
                "overrides": []
            }
        },
        {
            "id": 4,
            "title": "GPU Power",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rocm_gpu_power_watts",
                    "legendFormat": "GPU {{gpu_id}}",
                    "refId": "A"
                }
            ],
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "watt"
                },
                "overrides": []
            }
        }
    ],
    "templating": {
        "list": []
    },
    "schemaVersion": 39,
    "version": 2
}
