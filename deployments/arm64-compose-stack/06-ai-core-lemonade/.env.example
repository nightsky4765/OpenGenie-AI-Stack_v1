# Lemonade Core Config (ARM64)
USER_NAME=wrt
BASE_DIR=/home/wrt/TigerAI
MODELS_DIR=/home/wrt/TigerAI/models
LOG_DIR=/home/wrt/TigerAI/lemonade-logs

# Model Files (Place these in MODELS_DIR)
LLM_MODEL=gpt-oss-20b-mxfp4.gguf
EMBED_MODEL=Qwen3-Embedding-8B-Q8_0.gguf

# API Security
LEMONADE_API_KEY=CHANGE_ME

# Hardware Mapping
GGML_VULKAN_DEVICE_EDU=0
GGML_VULKAN_DEVICE_RAG=0
GGML_VULKAN_DEVICE_EMBED=0
